# ==========================================================
# Urban Mobility Disruption Copilot — Environment Variables
# ==========================================================
# Copy to .env and adjust as needed:  cp .env.example .env

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
LOG_LEVEL=info

# --- Forecast Region (Portland — trained ST-GAT model) ---
CITY_NAME=portland
CITY_CENTER_LAT=45.5152
CITY_CENTER_LON=-122.6784
CITY_RADIUS_KM=8

# --- Service Area Bias (optional geocoding bias) ---
# Set SERVICE_AREA_ENABLED=false for fully unbiased global search
SERVICE_AREA_ENABLED=true
SERVICE_AREA_MIN_LAT=45.25
SERVICE_AREA_MAX_LAT=45.75
SERVICE_AREA_MIN_LON=-123.1
SERVICE_AREA_MAX_LON=-122.3

# --- OSRM Routing (global road geometry) ---
# Public demo server — suitable for development and portfolio demos
# For production: self-host OSRM or use a paid routing API
OSRM_BASE_URL=https://router.project-osrm.org

# --- Data Paths ---
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_SYNTHETIC_DIR=data/synthetic
VECTOR_STORE_DIR=data/vector_store
MODEL_CHECKPOINT_DIR=checkpoints

# --- ML Model ---
MODEL_NAME=stgat_v1
DEVICE=cpu

# --- Qdrant Vector Database ---
# Local: localhost:6333 | Docker: qdrant:6333
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=mobility_advisories

# --- Embedding Model (sentence-transformers) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Weather API (Open-Meteo — free, no key needed) ---
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast

# --- GTFS (TriMet Portland) ---
GTFS_URL=https://developer.trimet.org/schedule/gtfs.zip
GTFS_RT_ENABLED=false

# --- Frontend ---
# Set to your deployed backend URL for production
NEXT_PUBLIC_API_URL=http://localhost:8000
